&&                  # Объединение команд, при условии успешного выполнения предыдущей
|                   # Передача выходных данных одной команды на вход другой
>                   # Перенаправление выходных данных в файл + его перезапись
>>                  # Перенаправление выходных данных в конец файла
mkdir "$(whoami)"   # Создание папки с именем текущего пользователя (вывод whoami передается в mkdir)
